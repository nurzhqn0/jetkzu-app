# Copy to .env and adjust as needed.

# JWT
JWT_SECRET=please-change-me-in-production

# SMTP — leave empty to use the built-in MockEmailSender (writes to logs/DB).
# For Gmail: enable 2FA on the account, create an App Password and paste below.
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=no-reply@jetkzu.kz
