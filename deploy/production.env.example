APP_TAG=latest

POSTGRES_USER=jetkzu
POSTGRES_PASSWORD=change-this-postgres-password
JWT_SECRET=change-this-long-random-jwt-secret

GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=change-this-grafana-password

# Bound to localhost on the VPS by docker-compose.prod.yml.
PROMETHEUS_HOST_PORT=9090
GRAFANA_HOST_PORT=3001

# Optional real SMTP settings. Empty values use the mock sender.
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=no-reply@jetkzu.nurzhqn.com
