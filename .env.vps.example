# Copy this file to .env.vps on the VPS and replace every production secret.
# Keep POSTGRES_PASSWORD URL-safe: letters, numbers, underscore, and dash are safest.

POSTGRES_PASSWORD=change-me-postgres-password
JWT_SECRET=change-me-long-random-jwt-secret
JWT_TTL=24h

# Frontend container listener. Host Nginx serves https://jetkzu.nurzhqn.com
# and proxies to this local-only port.
FRONTEND_BIND_ADDR=127.0.0.1
FRONTEND_HOST_PORT=3009

# Local-only operational endpoints. Access with SSH tunnels if needed.
GATEWAY_BIND_ADDR=127.0.0.1
GATEWAY_HOST_PORT=8080
PROMETHEUS_BIND_ADDR=127.0.0.1
PROMETHEUS_HOST_PORT=9090
GRAFANA_BIND_ADDR=127.0.0.1
GRAFANA_HOST_PORT=3001
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=change-me-grafana-password

# SMTP is optional. Leave empty to use the built-in mock sender.
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=no-reply@jetkzu.kz

# Optional image tags if you later push images to a registry.
BACKEND_IMAGE=jetkzu-backend:prod
FRONTEND_IMAGE=jetkzu-frontend:prod
